{
  "manifest_version": 3,
  "name": "InboxCommander",
  "version": "1.0.0",
  "description": "AI-powered email assistant that can read, summarize, classify, draft, reply, delete, archive, and label emails — InboxCommander",

  "icons": {
    "16": "assets/icons/logo-16.png",
    "32": "assets/icons/logo-32.png",
    "48": "assets/icons/logo-48.png",
    "128": "assets/icons/logo-128.png"
  },

  "permissions": ["storage", "sidePanel", "tabs", "activeTab", "identity", "alarms"],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://gmail.googleapis.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "__GOOGLE_OAUTH_CLIENT_ID__",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.modify",
      "https://www.googleapis.com/auth/gmail.send",
      "https://www.googleapis.com/auth/gmail.labels"
    ]
  },

  "background": {
    "service_worker": "background/service-worker.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content/content.ts"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "action": {
    "default_popup": "popup/popup.html"
  },

  "options_page": "options/options.html"
}
